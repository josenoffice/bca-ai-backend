# ── Required ──────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=your-anthropic-api-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key for the /admin/reset endpoint — choose any random string
ADMIN_SECRET=your-admin-secret-here

# Cloudflare Turnstile secret key (get from dash.cloudflare.com → Turnstile)
TURNSTILE_SECRET=your-turnstile-secret-key-here

# Comma-separated list of allowed CORS origins (leave blank to allow all — dev only)
# Example: https://your-app.onrender.com,https://yourdomain.com
ALLOWED_ORIGINS=
